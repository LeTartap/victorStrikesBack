# Used by docker compose for the API service (copy to `.env` in the same folder as docker-compose.yml)

# First boot only: creates the David (admin) user if the database has no users yet.
# After Victor and mediator accounts exist, you can remove these from .env if you prefer.
BOOTSTRAP_DAVID_USERNAME=david
BOOTSTRAP_DAVID_PASSWORD=change-me-to-a-strong-password

# Optional: session lifetime in days (default 7)
# SESSION_DAYS=7
